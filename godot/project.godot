; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but can be edited manually if done correctly.
;
; Format:
;   [section] ; section goes between []
;   param=val ; assign values to parameters
;
; Built-in GDScript 2.0 / Godot 4.x

config_version=5

[application]

config/name="Belagerungs-Atlas"
config/description="Procedural castle visualizer — Godot port of the web diorama engine"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[physics]

common/physics_ticks_per_second=60

[rendering]

textures/canvas_textures/default_texture_filter=1
environment/defaults/default_clear_color=Color(0.04, 0.04, 0.06, 1)

